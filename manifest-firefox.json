{
  "manifest_version": 3,
  "name": "Tradutor Libras - Reunioes",
  "version": "2.4",
  "description": "Traduz legendas de reunioes online para Libras usando VLibras com avatar 3D integrado",
  "browser_specific_settings": {
    "gecko": {
      "id": "tradutor-libras@extensao-libras",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://teams.microsoft.com/*",
    "https://*.zoom.us/*",
    "https://*.youtube.com/*",
    "https://vlibras.gov.br/*",
    "https://*.vlibras.gov.br/*",
    "https://traducao2.vlibras.gov.br/*",
    "https://dicionario2.vlibras.gov.br/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://*.zoom.us/*",
        "https://*.youtube.com/*"
      ],
      "js": ["contentScript.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "sidebar_action": {
    "default_panel": "sidepanel/sidepanel.html",
    "default_title": "Tradutor Libras",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tradutor Libras",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "styles.css", "vlibras-widget/*"],
      "matches": ["https://meet.google.com/*", "https://teams.microsoft.com/*", "https://*.zoom.us/*", "https://*.youtube.com/*"]
    }
  ]
}
